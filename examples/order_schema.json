{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "orders": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "order_id": {"type": "integer"},
          "customer_id": {"type": "integer"},
          "amount": {"type": "number"},
          "status": {"type": "string"}
        },
        "required": ["order_id", "customer_id", "amount", "status"]
      }
    }
  },
  "required": ["orders"]
}
