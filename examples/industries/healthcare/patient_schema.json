{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "patient_id": {
      "type": "string",
      "pattern": "^P\\d{3}$"
    },
    "gender": {
      "type": "string",
      "enum": ["M", "F"]
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120
    },
    "blood_type": {
      "type": "string",
      "pattern": "^(A|B|AB|O)[+-]$"
    },
    "diagnosis_date": {
      "type": "string",
      "format": "date"
    },
    "medication": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["patient_id", "gender", "age", "blood_type", "diagnosis_date", "medication"]
}
